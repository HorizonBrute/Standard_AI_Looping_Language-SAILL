*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
*.der
*.csr
*.jks
*.keystore
*.asc
*.gpg
*.pgp

# SSH keys & config
id_rsa
id_ed25519
id_ecdsa
id_dsa
authorized_keys
known_hosts
.ssh/

# Generic secret/credential directories
secrets/
secrets.*
secret.*
credentials
credentials.*
.credentials/
.secrets/

# Cloud provider credentials
