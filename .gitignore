# Token & auth files
*.token
*.tokens
*.jwt
*.refresh_token
auth.json
.vault-token
.github_token
.slack_token
oauth_token
oauth2_token
.oauth/

# Named config files that regularly contain credentials
config/local.json
config/secrets.json
config/local.*
config/production.*
local.settings.json

# Password-pattern filename globbing
*apikey*
*api_key*
*access_token*
*private_key*
*secret_key*
*client_secret*
*password*
*passwd*
*.vault
*-secret.json
*-credentials.json
*-key.json
*secrets*.json
*secrets*.yml
*secrets*.yaml
*credentials*.json
*credentials*.yml

# Package manager auth tokens
.npmrc
.yarnrc
.pypirc
.gem/credentials
.pip/pip.conf

# Terraform
*.tfstate
*.tfstate.*
.terraform/
terraform.tfvars

# Shell history (may contain secrets typed inline)
.bash_history
.zsh_history
.fish_history
.history

